# ============================================
# Gmail SMTP 설정 (curl.sh에서 사용)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# Cypress Cloud 설정
# ============================================
CYPRESS_RECORD_KEY=your_cypress_record_key

# ============================================
# 실행 환경 설정
# ============================================
ENVIRONMENT=Docker

# ============================================
# Google Drive 설정
# ============================================
# Google Drive 폴더 ID 찾는 방법:
# 1. Google Drive에서 폴더 열기
# 2. URL에서 폴더 ID 복사
#    https://drive.google.com/drive/folders/1ABC123xyz...  ← 이 부분이 폴더 ID
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ============================================
# Site URLs
# ============================================
SITE_DEV=https://dev.example.com/
SITE_DEV_ADMIN=https://dev-admin.example.com/
SITE_PROD=https://example.com/
SITE_PROD_ADMIN=https://admin.example.com/
SITE_STG=https://stg.example.com/
SITE_STG_ADMIN=https://stg-admin.example.com/

# ============================================
# 일반 테스트 계정
# ============================================
ID_TEST01=test01@example.com
ID_TEST02=test02@example.com
ID_TEST03=test03@example.com
ID_ADMIN=admin@example.com
PW_PUBLIC=your_public_password
PW_ADMIN=your_admin_password

# ============================================
# Global Money Express - Live 환경
# ============================================
LIVE_GME=http://your-live-server:port/Admin
LIVE_ID_GME01=your_live_username
LIVE_PW_GME01=your_live_password
LIVE_CODE_GME01=your_live_company_code

# ============================================
# Global Money Express - Staging 환경
# ============================================
STG_GME=http://your-stg-server:port/Admin
STG_ID_GME01=your_stg_username
STG_PW_GME01=your_stg_password
STG_CODE_GME01=your_stg_company_code

# ============================================
# 고객 테스트 데이터 (민감정보)
# ============================================
CUSTOMER_ID_NUMBER=YYMMDD-XXXXXXX
CUSTOMER_NAME=홍길동
BANK_A_NAME=Bank Name A
BANK_A_ACCOUNT=0000000000000
BANK_B_NAME=Bank Name B
BANK_B_ACCOUNT=0000000000000

# ============================================
# 검색 키워드 (테스트 코드에서 사용)
# ============================================
SEARCH_USERNAME=test_username
